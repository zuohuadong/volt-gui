{
  "name": "voltui-desktop-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node ../scripts/build-wails-frontend.mjs",
    "build:react": "tsc --noEmit && vite build",
    "build:svelte": "node ../scripts/build-wails-frontend.mjs svelte",
    "sync:svelte-dist": "node ../scripts/sync-workbench-dist.mjs",
    "preview": "vite preview",
    "test:todo-visibility": "node scripts/test-todo-visibility.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "highlight.js": "^11.10.0",
    "katex": "^0.17.0",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "terser": "^5.48.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.7"
  },
  "pnpm": {
    "overrides": {
      "mdast-util-gfm-autolink-literal": "2.0.0"
    }
  }
}
