---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const repo = 'https://github.com/zuohuadong/volt-gui';
---
<footer class="site-footer">
  <div class="wrap foot">
    <a class="brand" href={`${base}/`}><span class="mk">V</span><span>VoltUI</span></a>
    <div class="foot-copy">© 2026 VoltUI · <span class="l-en">MIT licensed</span><span class="l-zh">MIT 许可</span></div>
    <nav class="foot-links" aria-label="Footer navigation">
      <a href={`${base}/usage/`}><span class="l-en">Usage</span><span class="l-zh">用量</span></a>
      <a href={`${base}/enterprise/`}><span class="l-en">Enterprise</span><span class="l-zh">企业</span></a>
      <a href={`${base}/docs/`}><span class="l-en">Docs</span><span class="l-zh">文档</span></a>
      <a href={repo}>GitHub</a>
    </nav>
  </div>
</footer>
