---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const repo = 'https://github.com/zuohuadong/volt-gui';
const { active = '' } = Astro.props;

const items = [
  { key: 'capabilities', href: base + '/capabilities/', en: 'Capabilities', zh: '产品能力' },
  { key: 'enterprise', href: base + '/enterprise/', en: 'Enterprise deployment', zh: '企业部署' },
  { key: 'usage', href: base + '/usage/', en: 'Security & usage', zh: '安全与用量' },
  { key: 'docs', href: base + '/docs/', en: 'Docs', zh: '文档' },
];
---
<header id="nav" class="site-nav">
  <div class="wrap nav">
    <a class="brand" href={base + '/'} aria-label="VoltUI home"><span class="mk">V</span><span>VoltUI</span></a>
    <nav class="nav-links" aria-label="Primary navigation">
      {items.map((item) => (
        <a href={item.href} class:list={{ here: active === item.key }} aria-current={active === item.key ? 'page' : undefined}>
          <span class="l-en">{item.en}</span><span class="l-zh">{item.zh}</span>
        </a>
      ))}
      <a href={repo}>GitHub</a>
    </nav>
    <details class="mobile-nav">
      <summary><span class="l-en">Menu</span><span class="l-zh">导航</span></summary>
      <nav aria-label="Mobile navigation">
        {items.map((item) => (
          <a href={item.href} class:list={{ here: active === item.key }} aria-current={active === item.key ? 'page' : undefined}>
            <span class="l-en">{item.en}</span><span class="l-zh">{item.zh}</span>
          </a>
        ))}
        <a href={repo}>GitHub</a>
      </nav>
    </details>
    <div class="nav-right">
      <button class="lang" id="lang" type="button" aria-label="Switch language">中文</button>
      <a class="btn btn-dark" href={base + '/enterprise/'}><span class="l-en">Deployment guide</span><span class="l-zh">部署指南</span></a>
    </div>
  </div>
</header>
