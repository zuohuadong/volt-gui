---
import '../styles/global.css';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const { title, description, titleEn = title, titleZh = title, bodyClass = '' } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL(`${base}/og.png`, Astro.site).href;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <link rel="icon" href={`${base}/favicon.svg`} type="image/svg+xml" />
  <meta name="theme-color" content="#f6f5f2" />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="VoltUI" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImage} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <slot name="head" />
</head>
<body
  class={bodyClass}
  data-motion="rich"
  data-lang="en"
  data-title-en={titleEn}
  data-title-zh={titleZh}>
  <slot />
  <script>
    import '../scripts/site.js';
    import '../scripts/fx.js';
  </script>
</body>
</html>
