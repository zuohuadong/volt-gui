npm i -g reasonix

<span class="c"># Homebrew</span>
brew install esengine/reasonix/reasonix</div>
      <div class="doc-choice-grid">
        <div>
          <strong><span class="l-en">Use the CLI when</span><span class="l-zh">适合用 CLI</span></strong>
