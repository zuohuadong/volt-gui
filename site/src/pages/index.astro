---
import Base from '../layouts/Base.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const R2 = 'https://dl.voltui.io/latest';
const repo = 'https://github.com/zuohuadong/volt-gui';

let goVer = '1.17';
try {
  const r = await fetch(`${R2}/latest.json`);
  if (r.ok) { const d = await r.json(); goVer = String(d.version || '').replace(/^v/, '') || goVer; }
} catch {}
---
<Base
  title="VoltUI — Enterprise AI coding agent for your intranet"
  titleEn="VoltUI — Enterprise AI coding agent for your intranet"
  titleZh="VoltUI — 面向企业内网的 AI 编码 Agent"
  bodyClass="home-page"
  description="Offline-first, multi-model AI coding agent for enterprise intranets. Single Go binary, Windows 10 ready, white-label deployment, MCP plugins, usage tracking. MIT licensed.">

  <SiteHeader active="home" />

  <a id="top"></a>
  <header class="hero wrap">
    <div class="kicker"><span class="dot"></span><span class="l-en">Open source · MIT · v{goVer} · Single Go binary</span><span class="l-zh">开源 · MIT · v{goVer} · 单 Go 二进制</span></div>
    <h1>
      <span class="l-en">AI coding agent for your <em>enterprise intranet</em>.</span>
      <span class="l-zh">面向<em>企业内网</em>的 AI 编码 Agent。</span>
    </h1>
    <p class="lede">
      <span class="l-en">Offline-first, multi-model, Windows-ready. Deploy one binary — every developer on your intranet is productive. DeepSeek, Qwen, GLM, Claude, any OpenAI-compatible endpoint.</span>
      <span class="l-zh">离线优先、多模型、Windows 开箱即用。下发一个二进制，内网全员上手。支持 DeepSeek、通义千问、智谱 GLM、Claude 及任何 OpenAI 兼容端点。</span>
    </p>
    <div class="hi">
      <div class="hi-tabs" role="tablist" aria-label="Installation method">
        <button class="htab on" id="tab-npm" data-h="npm" role="tab" aria-selected="true" aria-controls="panel-npm">npm</button>
        <button class="htab" id="tab-brew" data-h="brew" role="tab" aria-selected="false" aria-controls="panel-brew">Homebrew</button>
        <button class="htab" id="tab-dl" data-h="dl" role="tab" aria-selected="false" aria-controls="panel-dl"><span class="l-en">Download</span><span class="l-zh">下载</span></button>
      </div>
      <div class="hi-body">
        <div class="hpanel on" id="panel-npm" data-h="npm" role="tabpanel" aria-labelledby="tab-npm">
          <div class="cmdgroup">
            <div class="cmdtag pre"><span class="l-en">v{goVer} · Go binary</span><span class="l-zh">v{goVer} · Go 二进制</span></div>
            <div class="cmdrow"><span class="hcmd"><span class="p">$ </span>npm i -g voltui@next</span><button class="cp" data-copy="npm i -g voltui@next"><span class="l-en">Copy</span><span class="l-zh">复制</span></button></div>
            <div class="cmdrow"><span class="hcmd"><span class="p">$ </span>voltui</span><button class="cp" data-copy="voltui"><span class="l-en">Copy</span><span class="l-zh">复制</span></button></div>
          </div>
        </div>
        <div class="hpanel" id="panel-brew" data-h="brew" role="tabpanel" aria-labelledby="tab-brew">
          <div class="cmdgroup">
            <div class="cmdtag pre"><span class="l-en">v{goVer} only</span><span class="l-zh">仅 v{goVer}</span></div>
            <div class="cmdrow"><span class="hcmd"><span class="p">$ </span>brew install esengine/voltui/voltui</span><button class="cp" data-copy="brew install esengine/voltui/voltui"><span class="l-en">Copy</span><span class="l-zh">复制</span></button></div>
            <div class="cmdrow"><span class="hcmd"><span class="p">$ </span>voltui</span><button class="cp" data-copy="voltui"><span class="l-en">Copy</span><span class="l-zh">复制</span></button></div>
          </div>
        </div>
        <div class="hpanel" id="panel-dl" data-h="dl" role="tabpanel" aria-labelledby="tab-dl">
          <div class="dlgroup">
            <div class="dllabel"><span class="dot ok"></span><span class="l-en">Desktop · v{goVer}</span><span class="l-zh">桌面端 · v{goVer}</span></div>
            <div class="dlrow">
              <a class="hdl" href={`${R2}/VoltUI-darwin-arm64.zip`}>macOS · Apple Silicon</a>
              <a class="hdl" href={`${R2}/VoltUI-windows-amd64-installer.exe`}>Windows · x64</a>
              <a class="hdl" href={`${R2}/VoltUI-linux-amd64.tar.gz`}>Linux · x64</a>
            </div>
            <a class="dlmore" href={`${repo}/releases/latest`}><span class="l-en">All releases →</span><span class="l-zh">全部版本 →</span></a>
          </div>
        </div>
      </div>
    </div>
  </header>

  <!-- Bento Grid: Product Capabilities -->
  <section id="features" class="bento-section wrap reveal">
    <div class="section-head">
      <h2><span class="l-en">Built for how teams actually ship.</span><span class="l-zh">为团队实际交付而生。</span></h2>
      <p class="section-sub"><span class="l-en">Every capability maps to a real pain point in enterprise AI adoption.</span><span class="l-zh">每个能力都直指企业 AI 落地的真实痛点。</span></p>
      <a class="section-link" href={`${base}/capabilities/`}><span class="l-en">Explore all capabilities →</span><span class="l-zh">查看全部产品能力 →</span></a>
    </div>
    <div class="bento">
      <!-- Hero card: multi-model -->
      <div class="card hero-card span-2 row-2">
        <div>
          <span class="tag"><span class="l-en">Any model · one config</span><span class="l-zh">任意模型 · 一行配置</span></span>
          <div class="icon">⇄</div>
          <h3><span class="l-en">Multi-model, no lock-in</span><span class="l-zh">多模型，不绑定</span></h3>
          <p><span class="l-en">DeepSeek, Qwen, GLM, Claude, MiMo, Ollama, vLLM — any OpenAI-compatible or Anthropic endpoint. One <code>[[providers]]</code> entry per model. Two-model collaboration (executor + planner) in a single line.</span><span class="l-zh">DeepSeek、通义千问、智谱 GLM、Claude、MiMo、Ollama、vLLM —— 任何 OpenAI 兼容或 Anthropic 端点。每个模型一个 <code>[[providers]]</code> 配置项。双模型协同（执行器 + 规划器）一行开启。</span></p>
        </div>
        <div class="models">
          <span>DeepSeek</span><span>Qwen</span><span>GLM</span><span>Claude</span><span>MiMo</span><span>Ollama</span><span>vLLM</span>
        </div>
      </div>

      <!-- Usage card -->
      <div class="card usage-card row-2">
        <span class="demo-pill"><span class="l-en">Demo</span><span class="l-zh">演示</span></span>
        <div class="icon">◇</div>
        <h3><span class="l-en">Usage & cost visible</span><span class="l-zh">用量与成本可见</span></h3>
        <p><span class="l-en">Per-turn token accounting with cache hit/miss breakdown. <code>voltui usage</code> reports by day, model, and source.</span><span class="l-zh">逐回合 token 统计，缓存命中/未命中拆分。<code>voltui usage</code> 按天、模型、来源出报表。</span></p>
        <div class="metrics">
          <div class="metric"><div class="v">Hit / Miss</div><div class="l"><span class="l-en">cache breakdown</span><span class="l-zh">缓存命中拆分</span></div></div>
          <div class="metric"><div class="v">¥ · $</div><div class="l"><span class="l-en">cost by currency</span><span class="l-zh">按币种预估成本</span></div></div>
        </div>
        <div class="bars">
          <div class="bar-row"><span class="name">deepseek-v4</span><div class="bar"><div class="fill" style="width:52%"></div></div><span class="amt">52%</span></div>
          <div class="bar-row"><span class="name">qwen3-235b</span><div class="bar"><div class="fill" style="width:28%"></div></div><span class="amt">28%</span></div>
          <div class="bar-row"><span class="name">glm-4-plus</span><div class="bar"><div class="fill" style="width:14%"></div></div><span class="amt">14%</span></div>
        </div>
        <a class="card-link" href={`${base}/usage/`}><span class="l-en">Open compute & usage →</span><span class="l-zh">查看算力用量 →</span></a>
      </div>

      <!-- CodeGraph -->
      <div class="card">
        <div class="icon">⬡</div>
        <h3><span class="l-en">Code intelligence</span><span class="l-zh">代码智能</span></h3>
        <p><span class="l-en">Tree-sitter symbol/call-graph search — no embedding service, zero API cost. Auto-indexed on first use.</span><span class="l-zh">基于 tree-sitter 的符号/调用图搜索 —— 无需嵌入服务，零 API 成本。首次使用自动索引。</span></p>
      </div>

      <!-- Checkpoints -->
      <div class="card">
        <div class="icon">↶</div>
        <h3><span class="l-en">Checkpoints & rewind</span><span class="l-zh">检查点与回退</span></h3>
        <p><span class="l-en">Snapshot-based edit safety net. Press Esc-Esc or <code>/rewind</code> to undo any change.</span><span class="l-zh">基于快照的编辑安全网。按 Esc-Esc 或 <code>/rewind</code> 撤销任何改动。</span></p>
      </div>

      <!-- Plan mode -->
      <div class="card">
        <div class="icon">☑</div>
        <h3><span class="l-en">Plan mode + sandbox</span><span class="l-zh">计划模式 + 沙箱</span></h3>
        <p><span class="l-en">Writers jailed to the workspace. <code>/plan</code> gates the session read-only until you approve.</span><span class="l-zh">写工具关进工作区。<code>/plan</code> 进只读门，批准前不写盘。</span></p>
      </div>

      <!-- MCP plugins -->
      <div class="card">
        <div class="icon">⬢</div>
        <h3><span class="l-en">MCP plugins</span><span class="l-zh">MCP 插件</span></h3>
        <p><span class="l-en">External tools over stdio, SSE, or streamable HTTP. Drop in an <code>.mcp.json</code> and go.</span><span class="l-zh">外部工具通过 stdio、SSE、streamable HTTP 接入。放一个 <code>.mcp.json</code> 即可。</span></p>
      </div>

      <!-- Skills -->
      <div class="card">
        <div class="icon">★</div>
        <h3><span class="l-en">Skills & hooks</span><span class="l-zh">技能与钩子</span></h3>
        <p><span class="l-en">Markdown skill scripts with isolated tools. PreToolUse / PostToolUse / Stop hooks for workflow automation.</span><span class="l-zh">Markdown 技能脚本与隔离工具。PreToolUse / PostToolUse / Stop 钩子用于工作流自动化。</span></p>
      </div>

      <!-- Memory -->
      <div class="card">
        <div class="icon">◈</div>
        <h3><span class="l-en">Memory across sessions</span><span class="l-zh">跨会话记忆</span></h3>
        <p><span class="l-en"><code>VOLTUI.md</code> hierarchy + auto-memory store, folded into the cache-stable prefix so context carries across sessions.</span><span class="l-zh"><code>VOLTUI.md</code> 层级 + 自动记忆存储，折叠进缓存稳定前缀，跨会话保持上下文。</span></p>
      </div>
    </div>
  </section>

  <!-- Enterprise Section -->
  <section id="enterprise" class="ent-section wrap reveal">
    <div class="section-head">
      <h2><span class="l-en">Deploy once. Everyone's productive.</span><span class="l-zh">部署一次，全员上手。</span></h2>
      <p class="section-sub"><span class="l-en">Built for enterprises running LLMs behind a firewall.</span><span class="l-zh">为在防火墙后运行大模型的企业打造。</span></p>
      <a class="section-link" href={`${base}/enterprise/`}><span class="l-en">See the enterprise rollout →</span><span class="l-zh">查看企业部署方案 →</span></a>
    </div>
    <div class="ent-grid">
      <div class="card">
        <div class="icon">⚙</div>
        <h3><span class="l-en">Pre-packaged deployment</span><span class="l-zh">打包即部署</span></h3>
        <p><span class="l-en">Preconfigure the model endpoint and operating policy, then inject credentials through environment variables or the credential store at deployment. Distribute a ready-to-run package without hardcoding keys.</span><span class="l-zh">预置模型地址与运行策略，在部署时通过环境变量或凭据存储注入密钥。分发开箱即用的安装包，不在二进制中硬编码 Key。</span></p>
      </div>
      <div class="card">
        <div class="icon">🔋</div>
        <h3><span class="l-en">Offline-first</span><span class="l-zh">离线优先</span></h3>
        <p><span class="l-en">No npm, no auto-downloads, no telemetry calls. Works entirely behind corporate firewalls. <code>CGO_ENABLED=0</code> static binary.</span><span class="l-zh">无 npm、无自动下载、无遥测回传，完全在防火墙内运行。<code>CGO_ENABLED=0</code> 静态二进制。</span></p>
      </div>
      <div class="card">
        <div class="icon">⌘</div>
        <h3><span class="l-en">Windows 10 first</span><span class="l-zh">Windows 10 优先</span></h3>
        <p><span class="l-en">Edge (Chromium) pre-installed on Win10 — <code>browser_navigate</code> works out of the box. Windows path detection, RDP/VDI friendly.</span><span class="l-zh">Win10 自带 Edge（Chromium 内核）—— <code>browser_navigate</code> 零配置可用。Windows 路径检测，RDP/VDI 友好。</span></p>
      </div>
      <div class="card">
        <div class="icon">◇</div>
        <h3><span class="l-en">White-label / OEM</span><span class="l-zh">白标 / OEM</span></h3>
        <p><span class="l-en">Replace product name and logos via config — no rebuild. <code>[brand] name</code>, <code>logo_path</code>, <code>VOLTUI_BRAND_NAME</code> env var.</span><span class="l-zh">通过配置替换产品名和 Logo —— 无需重新编译。<code>[brand] name</code>、<code>logo_path</code>、<code>VOLTUI_BRAND_NAME</code> 环境变量。</span></p>
      </div>
      <div class="card">
        <div class="icon">☰</div>
        <h3><span class="l-en">Config-driven</span><span class="l-zh">配置驱动</span></h3>
        <p><span class="l-en">Providers, tools, permissions, plugins — all in <code>voltui.toml</code>. No hardcoded models. One file per team, checked into the repo.</span><span class="l-zh">Provider、工具、权限、插件 —— 全部在 <code>voltui.toml</code> 中声明。无硬编码模型。一个文件管一个团队，直接提交仓库。</span></p>
      </div>
      <div class="card">
        <div class="icon">⬗</div>
        <h3><span class="l-en">IM bot integration</span><span class="l-zh">IM 机器人集成</span></h3>
        <p><span class="l-en">QQ, Feishu, WeChat bot gateways built-in. Developers trigger tasks and approve actions directly from IM.</span><span class="l-zh">内置 QQ、飞书、微信机器人网关。开发者直接在 IM 中触发任务和审批操作。</span></p>
      </div>
    </div>
  </section>

  <!-- CTA Band -->
  <section id="install" class="wrap reveal">
    <div class="cta-band">
      <h2><span class="l-en">Start in one line.</span><span class="l-zh">一行开始。</span></h2>
      <p><span class="l-en">Point it at your internal model endpoint and leave it running.</span><span class="l-zh">指向你的内部模型端点，然后让它跑着。</span></p>
      <div class="cta-row">
        <a class="btn btn-white" href={`${base}/docs/`}><span class="l-en">Read the docs</span><span class="l-zh">阅读文档</span></a>
        <a class="btn btn-out" href={repo}><span class="l-en">Star on GitHub</span><span class="l-zh">GitHub 加星</span></a>
      </div>
      <div style="margin-top:28px">
        <div class="cmdrow" style="display:inline-flex;align-items:center;gap:14px;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:11px;padding:10px 14px">
          <span class="hcmd" style="color:rgba(255,255,255,.85)"><span class="p" style="color:rgba(255,255,255,.3)">$ </span>npm i -g voltui@next</span>
          <button class="cp" data-copy="npm i -g voltui@next" style="background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.1);color:rgba(255,255,255,.6)"><span class="l-en">Copy</span><span class="l-zh">复制</span></button>
        </div>
      </div>
    </div>
  </section>

  <SiteFooter />
</Base>
